# Application Configuration
APP_NAME=DreamJournalAI
APP_ENV=development
LOG_LEVEL=INFO

# Database Configuration
PostgreSQL_URL=postgresql+asyncpg://user:password@host:port/database

# AI Services
GOOGLE_API_KEY=your_gemini_api_key_here
LLM_MODEL_NAME=gemini-2.0-flash-exp
OPENAI_API_KEY=your_openai_key_here  # Optional, legacy support

# Authentication
JWT_SECRET=your_jwt_secret_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# Dream Explorer Settings
# Embedding model for semantic search (sentence-transformers model name)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Maximum number of dreams to retrieve for context in conversational queries
MAX_RETRIEVED_DREAMS=5

# Minimum similarity threshold for dream retrieval (0.0 to 1.0)
# Higher values return only more similar dreams
SIMILARITY_THRESHOLD=0.6

# Enable conversation memory for multi-turn dialogues
ENABLE_CONVERSATION_MEMORY=true
